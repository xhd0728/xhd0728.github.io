source "https://rubygems.org"

# Native Jekyll. To upgrade, run `bundle update`.
#
#     bundle exec jekyll serve --livereload
#
gem "jekyll", "~> 4.4"

# Ruby 3.4+ no longer ships these as default gems; required by Jekyll's runtime.
gem "csv"
gem "base64"
gem "bigdecimal"
gem "logger"
gem "webrick"
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-sitemap"
  gem "jekyll-redirect-from"
end
